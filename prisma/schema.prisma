// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Role {
  MODERATOR
  VIEWER
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum Severity {
  HIGH
  MEDIUM
  LOW
}

// --- MODELS ---

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  users     User[]
  meetings  Meeting[]

  @@map("ORGANIZATIONS")
}

model User {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  fullName       String       @map("full_name")
  email          String       @unique
  passwordHash   String       @map("password_hash")
  role           Role         @default(MODERATOR)
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")

  meetings       Meeting[]    @relation("ModeratesMeetings")

  @@map("USERS")
}

model Meeting {
  id                   String        @id @default(uuid()) @db.Uuid
  organizationId       String        @map("organization_id") @db.Uuid
  organization         Organization  @relation(fields: [organizationId], references: [id])
  
  userId               String        @map("user_id") @db.Uuid
  user                 User          @relation("ModeratesMeetings", fields: [userId], references: [id])
  
  title                String
  agenda               String?       @db.Text // Toplantı öncesi girileceği için isteğe bağlı (optional) olabilir
  timelineResolutionMs Int           @default(2000) @map("timeline_resolution_ms") // Örn: 2000
  status               MeetingStatus @default(IN_PROGRESS)
  aiSummary            String?       @db.Text @map("ai_summary")
  
  startedAt            DateTime?     @map("started_at")
  endedAt              DateTime?     @map("ended_at")

  timelineData         TimelineData[]
  alerts               MeetingAlert[]

  @@map("MEETINGS")
}

model TimelineData {
  id         String   @id @default(uuid()) @db.Uuid
  meetingId  String   @map("meeting_id") @db.Uuid
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  offsetMs   Int      @map("offset_ms")
  payload    Json     // Focus, Emotion, Diarization JSON formatında
  
  @@index([meetingId, offsetMs])
  @@map("TIMELINE_DATA")
}

model MeetingAlert {
  id         String   @id @default(uuid()) @db.Uuid
  meetingId  String   @map("meeting_id") @db.Uuid
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  eventType  String   @map("event_type") // Örn: "LOW_FOCUS"
  severity   Severity
  message    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([meetingId])
  @@map("MEETING_ALERTS")
}
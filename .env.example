# ── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (Supabase / PostgreSQL) ────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
# Direct connection for migrations (Supabase: use Session pooler or direct host)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ── Redis ────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ─────────────────────────────────────────────
JWT_SECRET="change_me_to_a_strong_random_secret"
JWT_EXPIRES_IN="7d"

# ── Agenda alerts (live text worker tiers 20/40/65/90 as 0.20–0.90) ──
# AGENDA_DEVIATION_THRESHOLD=0.4
# AGENDA_RECOVERY_THRESHOLD=0.4
